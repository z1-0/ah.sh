{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppConfig",
  "type": "object",
  "properties": {
    "provider": {
      "$ref": "#/$defs/ProviderType"
    },
    "shell": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "provider"
  ],
  "$defs": {
    "ProviderType": {
      "type": "string",
      "enum": [
        "devenv",
        "dev-templates"
      ]
    }
  }
}