{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppConfig",
  "type": "object",
  "properties": {
    "log": {
      "anyOf": [
        {
          "$ref": "#/$defs/LogLevel"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider": {
      "$ref": "#/$defs/ProviderType"
    },
    "shell": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "provider"
  ],
  "$defs": {
    "LogLevel": {
      "type": "string",
      "enum": [
        "trace",
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "ProviderType": {
      "type": "string",
      "enum": [
        "devenv",
        "dev-templates"
      ]
    }
  }
}